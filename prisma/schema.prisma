// LocalBoost — Prisma schema
// Database provider: Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  googlePlaceId String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews   GoogleReview[]
}

// Historically Google-only; now stores customer feedback from any
// supported channel. The model name is kept for migration compatibility —
// callers should treat this as the generic "review" table and filter on
// `source` when channel matters.
model GoogleReview {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Where the review originated. Defaults to GOOGLE so existing rows
  // remain valid without a backfill.
  source       ReviewSource @default(GOOGLE)

  // Identifier from the upstream provider's payload (e.g. Google review id).
  // Nullable because DIRECT feedback collected through LocalBoost has no
  // external id. Postgres permits multiple NULLs under a unique constraint.
  externalId   String?  @unique
  reviewerName String?
  rating       Int
  comment      String?
  postedAt     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  response     ReviewResponse?

  // Covering indexes for the Review Management Dashboard. Every query is
  // scoped by businessId, so it leads each composite. postedAt / rating /
  // createdAt are the sortable columns; rating also doubles as the
  // star-filter equality column.
  @@index([businessId, postedAt])
  @@index([businessId, rating])
  @@index([businessId, createdAt])
  @@index([businessId, source])
}

enum ReviewSource {
  GOOGLE
  DIRECT
}

model ReviewResponse {
  id          String   @id @default(cuid())
  reviewId    String   @unique
  review      GoogleReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  // AI-generated response text
  content     String
  model       String
  promptTokens Int?
  completionTokens Int?
  status      ResponseStatus @default(DRAFT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ResponseStatus {
  DRAFT
  APPROVED
  PUBLISHED
  REJECTED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ReviewJob {
  id           String    @id @default(cuid())
  reviewId     String
  status       JobStatus @default(PENDING)
  errorMessage String?
  inputPayload Json
  responseId   String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
